# Database (Supabase)
DATABASE_URL=postgresql://postgres:password@localhost:54322/postgres
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OAuth
OAUTH_CLIENT_ID=couchloop_chatgpt
OAUTH_CLIENT_SECRET=your-oauth-secret-here
OAUTH_REDIRECT_URI=https://chat.openai.com/aip/plugin/oauth/callback

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# JWT Secret for OAuth tokens
JWT_SECRET=your-jwt-secret-here-min-32-chars

# Shrink-Chat Integration
SHRINK_CHAT_API_URL=https://shrink-chat.vercel.app
SHRINK_CHAT_API_KEY=your-shrink-chat-api-key-here
SHRINK_CHAT_TIMEOUT=30000

# Circuit Breaker Configuration
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60000
CIRCUIT_BREAKER_RESET=30000

# Feature Flags (V1)
ENABLE_SHRINK_CHAT_INTEGRATION=false
FALLBACK_TO_LOCAL_PROCESSING=true

# V2 Feature Flags
FF_V2_ROLLOUT_PCT=10                # Percentage of traffic using V2 (0-100)
FF_USE_V2_CLASSIFIER=true           # Use confidence-based classifier
FF_USE_V2_POLICY=true               # Use policy engine
FF_USE_V2_PLANNER=true              # Use execution planner
FF_USE_V2_EXECUTOR=false            # Use V2 executor (start false for safety)
FF_USE_V2_TELEMETRY=true            # Enable OpenTelemetry tracing
FF_DIRECT_ROUTE=true                # Enable direct routing for high confidence
FF_DIRECT_ROUTE_PCT=50              # Percentage of high-confidence going direct
FF_PARALLEL_EXECUTION=false         # Enable parallel DAG execution
FF_PARALLEL_EXEC_PCT=0              # Percentage of requests using parallel
FF_CACHING=false                    # Enable caching layer
FF_ADAPTIVE_TIMEOUTS=false          # Enable adaptive timeout calculation

# OpenTelemetry Configuration (Optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=mcp-orchestrator
OTEL_SERVICE_VERSION=2.0.0